{
  "name": "peasy-extension",
  "displayName": "Peasy Extension",
  "description": "Peasy Extension provides compilation support, a custom theme, syntax highlighting, a testing framework, error tracing visualization",
  "publisher": "PLanguage",
  "version": "1.1.0",
  "icon": "resources/p-icon.png",
  "license": "MIT",
  "homepage": "https://p-org.github.io/peasy-ide-vscode/",
  "bugs": {
    "url": "https://github.com/p-org/peasy-ide-vscode/issues"
  },
  "engines": {
    "vscode": "^1.79.0"
  },
  "activationEvents": [
    "onLanguage:p",
    "workspaceContains:**/*.p",
    "workspaceContains:**/*.pproj"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/p-org/peasy-ide-vscode.git"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Testing",
    "Visualization"
  ],
  "keywords": [
    "p-language",
    "formal-methods",
    "state-machines",
    "model-checking",
    "distributed-systems"
  ],
  "galleryBanner": {
    "color": "#0b132b",
    "theme": "dark"
  },
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "capabilities": {
    "virtualWorkspaces": false,
    "untrustedWorkspaces": {
      "supported": false,
      "description": "P compilation runs shell commands in the workspace."
    }
  },
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "peasy-visualizer",
          "title": "Peasy Visualizer",
          "icon": "resources/icons/P-icon.svg"
        }
      ]
    },
    "views": {
      "peasy-visualizer": [
        {
          "id": "peasy-visualizer-view",
          "name": "P Visualizer",
          "contents": "Visualize P error traces and state machines.\n[Run Visualizer](command:peasy-visualizer.run)\n[Compile Current Project](command:peasy.compile)\n[Show Project Files](command:peasy.showProjectFiles)\nLearn more at the [Peasy documentation](https://p-org.github.io/peasy-ide-vscode/)."
        }
      ]
    },
    "taskDefinitions": [
      {
        "type": "Run_Report"
      }
    ],
    "problemMatchers": [
      {
        "name": "Type",
        "fileLocation": [
          "search",
          {
            "include": [
              "${workspaceFolder}"
            ]
          }
        ],
        "pattern": [
          {
            "regexp": "(?:\\[Error:\\])"
          },
          {
            "regexp": "\\[([a-zA-Z\\/\\.]+):([0-9]+):([0-9]+)\\](.*)",
            "file": 1,
            "line": 2,
            "column": 3,
            "message": 4
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Parsing",
          "endsPattern": "~"
        }
      },
      {
        "name": "Parse",
        "fileLocation": [
          "search",
          {
            "include": [
              "${workspaceFolder}"
            ]
          }
        ],
        "pattern": [
          {
            "regexp": "(?:\\[Parser Error:\\])"
          },
          {
            "regexp": "\\[(.*)\\]\\s+(?:parse error:)\\s+(?:line\\s+)([0-9]+)\\:([0-9]+)(.+)",
            "file": 1,
            "line": 2,
            "column": 3,
            "message": 4
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Parsing",
          "endsPattern": "~"
        }
      },
      {
        "name": "Install_P"
      }
    ],
    "themes": [
      {
        "label": "P's Custom Theme",
        "uiTheme": "vs-dark",
        "path": "./src/ide/themes/PColorTheme.json"
      }
    ],
    "keybindings": [
      {
        "key": "f5",
        "command": "runCommands",
        "when": "editorLangId == p || resourceLangId == p || resourceExtname == .p",
        "args": {
          "commands": [
            {
              "command": "workbench.action.tasks.terminate",
              "args": "terminateAll"
            },
            {
              "command": "workbench.action.tasks.runTask",
              "args": "p-vscode: Compile"
            }
          ]
        }
      },
      {
        "key": "ctrl+b",
        "command": "runCommands",
        "when": "editorLangId == p || resourceLangId == p || resourceExtname == .p",
        "args": {
          "commands": [
            {
              "command": "workbench.action.tasks.terminate",
              "args": "terminateAll"
            },
            {
              "command": "workbench.action.tasks.runTask",
              "args": "p-vscode: Compile"
            }
          ]
        }
      },
      {
        "key": "f4",
        "command": "runCommands",
        "when": "editorLangId == p || resourceLangId == p || resourceExtname == .p",
        "args": {
          "commands": [
            {
              "command": "workbench.action.tasks.terminate",
              "args": "terminateAll"
            },
            {
              "command": "peasy.showProjectFiles"
            }
          ]
        }
      },
      {
        "key": "ctrl+l",
        "command": "runCommands",
        "when": "(editorLangId == p || resourceLangId == p || resourceExtname == .p) && !terminalFocus",
        "args": {
          "commands": [
            {
              "command": "workbench.action.tasks.terminate",
              "args": "terminateAll"
            },
            {
              "command": "peasy.showProjectFiles"
            }
          ]
        }
      },
      {
        "command": "peasy-visualizer.run",
        "key": "f6",
        "mac": "f6",
        "when": "(editorLangId == p || resourceLangId == p || resourceExtname == .p) && !inDebugMode"
      },
      {
        "command": "runCommands",
        "key": "f7",
        "when": "editorLangId == p || resourceLangId == p || resourceExtname == .p",
        "args": {
          "commands": [
            {
              "command": "workbench.action.tasks.terminate",
              "args": "terminateAll"
            },
            {
              "command": "workbench.action.tasks.runTask",
              "args": "p-vscode: Stately"
            }
          ]
        }
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Peasy Extension configuration",
      "properties": {
        "p-vscode.trace.server": {
          "scope": "window",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        },
        "p-vscode.schedules": {
          "scope": "window",
          "type": "integer",
          "default": 1000,
          "description": "Manages the number of schedules run during P testing at a 'p check' command."
        },
        "p-vscode.additionalArgs": {
          "scope": "window",
          "type": "string",
          "default": "",
          "description": "Manages the commandline arguments during P testing at a 'p check' command."
        },
        "p-vscode.pcompile.exclude": {
          "scope": "window",
          "type": "array",
          "default": [
            "**/Build/*",
            "**/build/**"
          ],
          "description": "Manages the folders that must be excluded from compiling in P."
        },
        "p-vscode.dotnetExecutablePath": {
          "scope": "machine-overridable",
          "type": "string",
          "default": "",
          "description": "Absolute path to the dotnet executable. Leave empty to resolve from PATH."
        },
        "p-vscode.languageServer.cliPath": {
          "scope": "machine-overridable",
          "type": "string",
          "default": "",
          "description": "Absolute path to the P language server (PLanguageServer.dll). When empty, the language server is disabled — automatic download is not yet implemented."
        },
        "p-vscode.languageServer.launchArgs": {
          "scope": "window",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional command-line arguments passed to the P language server."
        }
      }
    },
    "commands": [
      {
        "command": "peasy.showProjectFiles",
        "category": "Peasy",
        "title": "Show Project Files",
        "description": "Select a P project to compile from a VS Code Quick Pick."
      },
      {
        "command": "peasy-visualizer.run",
        "category": "PeasyViz",
        "title": "Run"
      },
      {
        "command": "peasy.compile",
        "category": "Peasy",
        "title": "Compile Current Project"
      }
    ],
    "languages": [
      {
        "id": "p",
        "aliases": [
          "P",
          "p"
        ],
        "extensions": [
          ".p",
          ".pproj"
        ],
        "configuration": "./src/ide/language/language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "p",
        "scopeName": "source.p",
        "path": "./src/ide/syntaxes/p.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "p",
        "path": "./src/ide/snippets/snippets.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm install && webpack --mode production",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "package:vsix": "npm run package && vsce package --no-dependencies --out peasy-extension.vsix",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "typecheck": "tsc -p . --noEmit"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.x",
    "@types/vscode": "^1.79.0",
    "@types/which": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^5.59.1",
    "@typescript-eslint/parser": "^5.59.1",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "2.32.0",
    "eslint": "^8.39.0",
    "eslint-import-resolver-typescript": "^3.5.5",
    "eslint-plugin-import": "^2.27.5",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "ts-loader": "^9.4.2",
    "typescript": "^5.0.4",
    "webpack": "^5.81.0",
    "webpack-cli": "^5.0.2"
  },
  "dependencies": {
    "cross-fetch": "^3.1.6",
    "extract-zip": "^2.0.1",
    "vscode-languageclient": "^8.1.0",
    "vscode-uri": "^3.0.7",
    "which": "^3.0.1"
  }
}
